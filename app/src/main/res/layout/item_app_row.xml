<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="4dp">

    <!-- Left zone: app icon + name (focusable, launches app) -->
    <LinearLayout
        android:id="@+id/appLaunchArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/row_background"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:padding="12dp"
        android:nextFocusRight="@+id/switchVpn">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="App icon" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageView
            android:id="@+id/ivShield"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_shield"
            android:visibility="gone"
            android:contentDescription="@string/vpn_required" />
    </LinearLayout>

    <!-- Right zone: VPN toggle (focusable) -->
    <Switch
        android:id="@+id/switchVpn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusLeft="@id/appLaunchArea"
        android:minHeight="48dp" />
</LinearLayout>
