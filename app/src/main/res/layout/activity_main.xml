<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp">

    <!-- Header bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivVpnStatus"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_vpn_disconnected"
                android:contentDescription="@string/vpn_disconnected" />

            <TextView
                android:id="@+id/tvVpnStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vpn_disconnected"
                android:textColor="@color/vpn_disconnected"
                android:textSize="14sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Quick access bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/row_background"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btnAppStore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_store"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/row_background"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btnVpn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/vpn"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/row_background"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btnRouterVpn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/router_vpn_short"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/row_background"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Edit mode hint -->
    <TextView
        android:id="@+id/tvEditHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/edit_mode_hint"
        android:textColor="@color/shield_icon"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="4dp"
        android:visibility="gone" />

    <!-- App grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAppGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />
</LinearLayout>
